<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to hold a MulticastLock so the Wi-Fi chip delivers broadcast
         and multicast UDP packets (e.g. discovery) to the app. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- Required to obtain a WifiManager instance and to create a WifiLock. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- Required to acquire a WifiLock (prevents Wi-Fi from sleeping during transfer). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <application android:hasCode="true" android:supportsRtl="true" android:icon="@mipmap/ic_launcher"
        android:extractNativeLibs="true"
        android:allowNativeHeapPointerTagging="false"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity android:configChanges="orientation|screenLayout|screenSize|keyboardHidden" android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name" android:name="dev.dioxus.main.MainActivity">
            <meta-data android:name="android.app.lib_name" android:value="dioxusmain" />
            <meta-data android:name="android.app.func_name" android:value="ANativeActivity_onCreate" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>
    </application>
</manifest>
